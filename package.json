{
  "name": "unocss-preset-overwrite",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "description": "Rebuild UnoCSS output with a new theme while keeping the same tokens.",
  "author": "chizukicn <https://github.com/chizukicn>",
  "license": "MIT",
  "homepage": "https://github.com/unocss-community/unocss-preset-overwrite#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unocss-community/unocss-preset-overwrite.git"
  },
  "bugs": {
    "url": "https://github.com/unocss-community/unocss-preset-overwrite/issues"
  },
  "keywords": [
    "unocss",
    "unocss-preset",
    "unocss-community",
    "unocss-preset-overwrite"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm run build",
    "release": "bumpp --commit --push --tag && pnpm publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:update": "vitest --update",
    "up:deps": "taze",
    "prepare": "npx simple-git-hooks"
  },
  "dependencies": {
    "@unocss/core": "^66.6.8",
    "maybe-types": "^0.2.0",
    "postcss": "^8.5.9",
    "postcss-selector-parser": "^7.1.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.1.1",
    "@babel/types": "^7.29.0",
    "@types/node": "^24.12.2",
    "@unocss/eslint-plugin": "^66.6.8",
    "@unocss/preset-attributify": "^66.6.8",
    "bumpp": "^11.0.1",
    "eslint": "^10.2.0",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "taze": "^19.11.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "unocss": "^66.6.8",
    "vitest": "^4.1.3",
    "vue": "^3.5.32"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix"
    ]
  }
}
